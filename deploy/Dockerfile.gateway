# yangble5 gateway (FastAPI) container image.
# ===========================================================================
# Build context is the REPO ROOT, not deploy/ — see docker-compose.yml:
#     docker compose build gateway
#
# The gateway source lives in ../gateway. This file only packages it; the
# gateway's own contract (routes, env vars) is documented in deploy/README.md.
# ===========================================================================

FROM python:3.12-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Non-root runtime identity.
#
# These are NOT decoration: docker-compose.yml passes YANGBLE5_UID/YANGBLE5_GID
# from .env as build args AND as the runtime `user:`, so the account baked here
# is the account the process runs as. When the two disagreed — .env carrying the
# host service user's id (typically in the 100-999 system range) while the image
# had hard-coded 10001 — the container ran as a uid that owned nothing, could not
# create /data/yangble5.db-wal, and SQLite failed on the first write.
#
# SQLite needs write access to the database file AND its directory, because the
# -wal and -shm files are created next to it.
ARG APP_UID=10001
ARG APP_GID=10001

# Created only if that id is free. A host service user allocated by
# `useradd --system` lands in a range where the base image may already have an
# account (Debian ships uid 100 `_apt`, gid 100 `users`, and more). Failing the
# build on such a collision would make the correct uid unusable for no reason —
# the id is what matters, not the name attached to it.
RUN if ! getent group "${APP_GID}" >/dev/null 2>&1; then \
        groupadd --gid "${APP_GID}" app; \
    fi \
 && if ! getent passwd "${APP_UID}" >/dev/null 2>&1; then \
        useradd --uid "${APP_UID}" --gid "${APP_GID}" --no-create-home \
                --shell /usr/sbin/nologin app; \
    fi

WORKDIR /app

# Dependencies first so edits to gateway source do not invalidate the pip layer.
COPY gateway/requirements.txt /tmp/requirements.txt
RUN python -m pip install --no-cache-dir -r /tmp/requirements.txt \
 && python -m pip install --no-cache-dir "uvicorn[standard]>=0.30" \
 && rm -f /tmp/requirements.txt

COPY gateway/ /app/gateway/

# tools/ rides along so the same image can run the optional `shim` service
# (`python -m tools.claude_shim`) without a second image to build and patch.
# It costs a few kB: claude_shim.py, cache_bench.py and cache_stats_sidecar.py
# are standard-library only and pull in no extra dependency.
COPY tools/ /app/tools/

# SQLite lives on a named volume mounted here. Created and chowned at build time
# because Docker initialises a FRESH named volume from the image's directory,
# ownership included — this chown is what makes the volume writable on first
# boot. It does nothing for a volume that already exists; install.sh repairs
# those separately when the uid changes.
RUN mkdir -p /data && chown -R "${APP_UID}:${APP_GID}" /data /app

# Numeric, not `app:app`: when the uid already existed in the base image no
# account named `app` was created, and the name would not resolve. The kernel
# only cares about the number anyway.
USER ${APP_UID}:${APP_GID}

ENV GATEWAY_PORT=8000 \
    GATEWAY_ASGI_APP=gateway.app:app

EXPOSE 8000

# WHY these uvicorn flags:
#   --proxy-headers + --forwarded-allow-ips
#       Only Caddy can reach this port (no published port, private Docker
#       network), so trusting forwarded headers from any peer on that network
#       is safe and is the only way the app sees the real client IP.
#   --timeout-keep-alive 75
#       Longer than Caddy's `keepalive 2m`? No — deliberately SHORTER, so the
#       idle connection is torn down by the origin, not mid-request by Caddy.
#   --no-server-header
#       One less thing advertising the stack; Caddy strips it too.
#   --workers is NOT set
#       SQLite plus multiple worker processes is a write-contention foot-gun.
#       Scale with async concurrency inside one process first; if you truly
#       need workers, move off SQLite first (see runbook.md).
CMD ["sh", "-c", "exec python -m uvicorn \"$GATEWAY_ASGI_APP\" --host 0.0.0.0 --port \"$GATEWAY_PORT\" --proxy-headers --forwarded-allow-ips='*' --timeout-keep-alive 75 --no-server-header"]

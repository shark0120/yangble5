# yangble5 public deployment — environment template
# ===========================================================================
# Copy to `.env` (install.sh does this for you) and keep it chmod 600.
# `.env` is gitignored. NEVER commit a filled-in copy.
#
# Lines whose value is exactly __GENERATE__ are replaced by install.sh with a
# freshly generated random secret. If you fill them in by hand, use at least
# 32 bytes of entropy: `openssl rand -hex 32`.
#
# NAMING: the gateway reads every setting as either BARE_NAME or
# YANGBLE5_BARE_NAME (see gateway/config.py::_raw). This file uses the
# YANGBLE5_ prefix throughout so nothing collides with another service's
# variables if you ever run the stack outside Docker.
# ===========================================================================

# ── 1. Edge / TLS ──────────────────────────────────────────────────────────
# The public hostname clients point ANTHROPIC_BASE_URL / OPENAI_BASE_URL at.
YANGBLE5_DOMAIN=yangble5.example.com

# Let's Encrypt account e-mail (expiry and problem notices go here).
ACME_EMAIL=admin@example.com

# Caddy build to run. The default is a CUSTOM build (see Dockerfile.caddy):
# stock `caddy:2` has NO rate_limit directive. If you point this at a stock
# image you MUST delete every `rate_limit` block in the Caddyfile, or Caddy
# refuses to start with "unrecognized directive: rate_limit".
CADDY_IMAGE=yangble5/caddy:local

# Host directory for Caddy's access log. fail2ban runs on the HOST and needs
# to read this file, which is why it is a bind mount and not a named volume.
# harden.sh points its jail at ${YANGBLE5_LOG_DIR}/caddy/access.log.
YANGBLE5_LOG_DIR=./logs

# ── 2. Gateway (the FastAPI service in ../gateway) ─────────────────────────
GATEWAY_IMAGE=yangble5/gateway:local

# Port the gateway listens on INSIDE its container. Never published to the host.
GATEWAY_PORT=8000

# SQLite database path inside the gateway container (backed by the
# `gateway_data` volume). This file holds users, key hashes, quotas and usage.
# Back it up — see runbook.md "Back up the database".
YANGBLE5_DB_PATH=/data/yangble5.db

# --- registration ---------------------------------------------------------
# invite  : new keys require an invite code you mint (DEFAULT, and the only
#           mode we recommend starting on for a public host).
# open    : anyone can self-register. The gateway REFUSES TO START in this
#           mode unless YANGBLE5_GLOBAL_MONTHLY_USD_BUDGET > 0 and at least
#           one per-key ceiling is set — because otherwise a stranger can
#           mint keys against your uncapped upstream balance.
# closed  : no new keys at all. Use this to freeze signups without taking the
#           service down.
YANGBLE5_REGISTRATION_MODE=invite

# THE OTHER GATE ON `open`, AND IT IS NOT ABOUT MONEY.
#
# The budget caps above bound what abuse can COST you. They say nothing about
# what abuse can get SUSPENDED. docs/OPERATING_A_PUBLIC_SERVICE.md §1 is the
# hard rule: pooled PERSONAL OAuth credentials must never back a public
# service. The engine's multi-credential failover exists so one person can
# spread their own usage across their own accounts — it is not a multi-tenant
# licence. Point strangers at it and one origin IP starts emitting the
# request-shape diversity of dozens of unrelated humans, which is precisely
# what provider abuse detection looks for. Rate-limit first, then suspension,
# and the suspension lands on the Google / xAI / OpenAI ACCOUNT — taking out
# everything else that account is used for. If a tier is served by ONE
# credential, that suspension is a total outage for that tier with no
# failover at all.
#
# Set this to `yes` ONLY if every credential the engine holds is on a plan
# whose terms permit serving third parties (check for language about resale,
# redistribution, proxying and multi-user access; if it is ambiguous, ask the
# provider in writing BEFORE you launch).
#
# install.sh REFUSES to configure YANGBLE5_REGISTRATION_MODE=open while this
# is `no`. That refusal is the point: `open` should require a deliberate
# statement, not merely the absence of an objection.
#
# Nothing reads this at runtime. It is an operator assertion, kept in .env so
# it is greppable and so the decision has a place to live.
YANGBLE5_POOL_LICENSED_FOR_THIRD_PARTIES=no

# Admin credential for the gateway's /admin/* surface (minting invite codes,
# listing and suspending keys).
#
# NOT OPTIONAL IN INVITE MODE. With REGISTRATION_MODE=invite and no admin key,
# /admin/invites is disabled, no invite code can be minted, and therefore
# nobody can register at all. The gateway says so in its startup warnings.
#
# install.sh generates this and prints it ONCE. After that, read it back out
# of this file as root — it is stored here in clear and nowhere else.
YANGBLE5_ADMIN_API_KEY=__GENERATE__

# One active key per e-mail address unless you set this true.
YANGBLE5_ALLOW_MULTIPLE_KEYS_PER_EMAIL=false

# Registration attempts allowed per client IP per day (the IP is stored hashed).
YANGBLE5_REGISTER_MAX_PER_IP_PER_DAY=5

# --- budgets --------------------------------------------------------------
# YOU are paying the upstream bill. Set these before you open registration.
# 0 means unlimited on every one of them.
#
# Per key, per day:
YANGBLE5_DAILY_TOKEN_BUDGET=2000000
YANGBLE5_DAILY_COST_USD_BUDGET=2.0
#
# Whole deployment, per calendar month. The value below is an EXAMPLE — pick a
# number you would be willing to lose, because that is the amount a runaway
# loop or a leaked key can cost you before the cap trips.
YANGBLE5_GLOBAL_MONTHLY_USD_BUDGET=50.0
#
# A token-denominated global ceiling, applied alongside the dollar one.
# Useful when your upstream bills in tokens or is a fixed-quota plan, where a
# dollar figure is a guess but a token count is exact. 0 = unlimited.
YANGBLE5_GLOBAL_MONTHLY_TOKEN_BUDGET=0
#
# Warn (in the logs) once monthly spend crosses this fraction of the cap.
YANGBLE5_GLOBAL_BUDGET_WARN_RATIO=0.9

# --- cost accounting ------------------------------------------------------
# The gateway ships a PLACEHOLDER price table, so `cost_usd` is an internal
# accounting unit, NOT a bill. Point this at a JSON file with your real
# per-model rates to make the numbers mean money. Until you do, the
# authoritative figure is your provider's own billing console.
# YANGBLE5_PRICE_TABLE_FILE=/data/prices.json

# --- crypto ---------------------------------------------------------------
# Server-side pepper mixed into every API-key hash. Key hashes are already
# salted per key; the pepper is what makes a stolen database file useless on
# its own, because the pepper lives in this .env and not in the database.
#
# ROTATING THIS INVALIDATES EVERY ISSUED KEY (the stored pepper_fp stops
# matching). Read runbook.md before you touch it.
YANGBLE5_KEY_PEPPER=__GENERATE__

# scrypt (default, stronger) or pbkdf2 (use only where scrypt's ~16 MiB per
# verification is genuinely a problem).
YANGBLE5_KEY_HASH_SCHEME=scrypt

# --- rate limits (gateway-side; the Caddyfile has its own edge limits) -----
YANGBLE5_RATE_LIMIT_RPM=60
YANGBLE5_RATE_LIMIT_CONCURRENCY=4
YANGBLE5_AUTH_RPM_PER_IP=10
YANGBLE5_AUTH_FAIL_LOCKOUT_THRESHOLD=8
YANGBLE5_AUTH_FAIL_LOCKOUT_SECONDS=300

# How long a successful authentication is cached, so the gateway does not run
# scrypt on every proxied request. The trade-off is directly operational: a
# suspension takes up to this long to bite unless you restart the gateway.
YANGBLE5_AUTH_CACHE_TTL_SECONDS=300

# --- abuse signals --------------------------------------------------------
# A key seen from this many distinct IPs inside the window is probably shared
# or resold. Auto-suspend is OFF by default: a false positive locks out a
# legitimate user on a mobile network, so the default is to flag, not act.
YANGBLE5_ABUSE_DISTINCT_IP_THRESHOLD=8
YANGBLE5_ABUSE_IP_WINDOW_HOURS=24
YANGBLE5_ABUSE_AUTO_SUSPEND=false

# --- transport ------------------------------------------------------------
# MUST be true in this stack: the gateway only ever sees Caddy as its peer, so
# without this every client looks like the Caddy container and both per-IP
# rate limiting and abuse detection become meaningless. TRUSTED_PROXY_HOPS=1
# because there is exactly one reverse proxy (Caddy) in front of the gateway.
# Cloudflare sits in front of CADDY, and Caddy resolves that hop itself via
# `trusted_proxies` + Cf-Connecting-Ip before it sets X-Real-IP.
YANGBLE5_TRUST_PROXY_HEADERS=true
YANGBLE5_TRUSTED_PROXY_HOPS=1

# Keep in sync with `request_body max_size` in the Caddyfile (32MB there).
YANGBLE5_MAX_REQUEST_BYTES=33554432

# How much of a response body the usage parser will scan. Bounded so a huge
# response cannot make the gateway allocate without limit.
YANGBLE5_MAX_USAGE_PARSE_BYTES=2097152

# Upstream read timeout, seconds. Must be LONGER than your longest expected
# generation: a coding agent on a 1M-context model can hold one response open
# for many minutes. 900s = 15 minutes.
YANGBLE5_UPSTREAM_TIMEOUT_SECONDS=900
YANGBLE5_UPSTREAM_CONNECT_TIMEOUT_SECONDS=10

YANGBLE5_LOG_LEVEL=INFO

# ── 3. Engine (CLIProxyAPI — you supply the binary/image) ──────────────────
# We do NOT redistribute CLIProxyAPI. Either:
#   (a) drop a linux/amd64 `cli-proxy-api` binary in ./engine-bin/ and let
#       Dockerfile.engine wrap it, or
#   (b) set ENGINE_IMAGE to an image you built or already trust.
ENGINE_IMAGE=yangble5/engine:local

# Where the gateway reaches the engine. A Docker-internal DNS name: not
# resolvable and not reachable from the internet.
#
# RUNNING CLIProxyAPI 7.1.23? Point this at the shim instead:
#     YANGBLE5_ENGINE_URL=http://shim:8320
# and start the stack with `--profile shim`. 7.1.23's antigravity STREAMING
# translator forwards messages[].role verbatim, so a Claude Code >= 2.1.x
# client that injects a mid-conversation role:"system" message gets a 400 from
# Gemini. Upstream fixed it in 7.2.93. After upgrading past 7.2.93, set this
# back to http://engine:8318 and drop the profile — see runbook.md.
YANGBLE5_ENGINE_URL=http://engine:8318

# The engine's own `api-keys:` entry. The gateway presents this upstream; end
# users never see it and never send it. It MUST match deploy/engine/config.yaml
# exactly — a mismatch shows up as every request returning 401.
YANGBLE5_ENGINE_API_KEY=__GENERATE__

# The engine's `remote-management.secret`. Used only from inside the compose
# network (stats sidecar, runbook commands). Caddy 404s /v0/* from the
# internet; this key is the second lock, not the first.
YANGBLE5_ENGINE_MANAGEMENT_KEY=__GENERATE__

# ── 4. Runtime identity ────────────────────────────────────────────────────
# UID/GID that owns the install prefix and runs the gateway + engine
# containers. install.sh overwrites these with the service user it creates.
YANGBLE5_UID=10001
YANGBLE5_GID=10001

# ── 5. Resource ceilings ───────────────────────────────────────────────────
# Tuned for a 2 vCPU / 4 GB VPS. The engine gets the largest share because a
# single request can carry a very large prompt: our reference measurement
# moved a 748,918-token prompt through it, which is several MB of JSON to
# parse, translate and re-serialise per request.
CADDY_CPUS=0.50
CADDY_MEM=256M
GATEWAY_CPUS=1.00
GATEWAY_MEM=512M
ENGINE_CPUS=1.50
ENGINE_MEM=2G
SHIM_CPUS=0.25
SHIM_MEM=256M

# ── 6. Optional: Cloudflare DNS-01 ─────────────────────────────────────────
# Only needed if you keep the DNS record PROXIED (orange cloud) and want Caddy
# to solve the ACME challenge over DNS. Requires the custom Caddy build (it
# bundles caddy-dns/cloudflare) and a scoped API token with Zone:DNS:Edit on
# this zone only. See cloudflare.md. Leave empty for the default HTTP/TLS-ALPN
# challenge.
CLOUDFLARE_API_TOKEN=

# yangble5 gateway — environment template
# =============================================================================
# Copy to `.env` (gitignored) and fill in. Keep it chmod 600.
#
# EVERY VALUE BELOW IS A PLACEHOLDER. There is not a single real credential in
# this file, and there must never be one. Generate your own with:
#     openssl rand -hex 32
#
# Every variable is also accepted with a YANGBLE5_ prefix (YANGBLE5_ENGINE_URL
# and ENGINE_URL are the same setting), so the gateway can share a machine with
# another service without a name collision.
#
# Anything marked REQUIRED makes the process refuse to start if it is missing.
# That is deliberate: a gateway that boots half-configured is a gateway that
# spends the operator's money in a way nobody intended.
# =============================================================================

# ── 1. Upstream engine ───────────────────────────────────────────────────────
# Where the internal CLIProxyAPI engine listens. This must NOT be reachable from
# the internet — the gateway is the only thing that should be able to talk to it.
ENGINE_URL=http://127.0.0.1:8318

# REQUIRED. The engine's own api-keys[] entry. The gateway injects this on every
# upstream call. End users never see it and never send it.
# NEVER reuse a value you have handed to a user, and never put a provider key
# (Gemini/OpenAI/xAI) here — the engine holds those, not the gateway.
ENGINE_API_KEY=replace-me-with-openssl-rand-hex-32

# Optional. The engine's remote-management key. The gateway does not use it for
# proxying; it is here so a sidecar sharing this env file can find it.
ENGINE_MANAGEMENT_KEY=

# How long to wait on the engine. The read timeout is long on purpose: a
# 748,918-token prompt legitimately takes minutes before its first token. The
# connect timeout is short so a dead engine cannot park every worker.
UPSTREAM_TIMEOUT_SECONDS=900
UPSTREAM_CONNECT_TIMEOUT_SECONDS=10

# ── 2. Storage ───────────────────────────────────────────────────────────────
# SQLite file holding users, key hashes, usage and invites. BACK THIS UP.
# The directory must be writable: SQLite needs to create -wal and -shm beside it.
DB_PATH=/data/yangble5.db

# ── 3. Registration ──────────────────────────────────────────────────────────
# invite  — a valid invite code is required. THE DEFAULT, and the safe one.
# open    — anyone can mint a key with NO invite and NO email verification, by
#           sending either a machine fingerprint or an email address. Requires a
#           budget cap (below); the process refuses to start without one.
# closed  — no self-service registration at all.
REGISTRATION_MODE=invite

# REQUIRED to administer the service (mint invites, suspend keys, read /admin/stats).
# Without it the entire /admin/* surface returns 404 — which also means an
# invite-only instance where nobody can ever be invited. Generate a real one.
ADMIN_API_KEY=replace-me-with-openssl-rand-hex-32

# Server-side pepper mixed into every key hash before the KDF. Strongly
# recommended: it means a stolen database alone is not enough to attack the
# hashes. WARNING: changing this invalidates every key already issued.
KEY_PEPPER=

# scrypt (default, recommended) or pbkdf2.
KEY_HASH_SCHEME=scrypt

# One key per email address unless you turn this on.
ALLOW_MULTIPLE_KEYS_PER_EMAIL=false

# Registration ATTEMPTS allowed from one IP per UTC day. 0 disables the check.
# Counts every call, including rejected ones, so guessing invite codes is not
# free. See MAX_KEYS_PER_IP below for the other, different counter.
REGISTER_MAX_PER_IP_PER_DAY=5

# ── 3b. Open-mode machine binding (LOOSE on purpose) ─────────────────────────
# In open mode the installer sends `machine_id`: an opaque sha256 hex digest
# (16-64 hex characters). Anything that is not plain hex is REJECTED, never
# stored. The gateway never learns what was hashed into it.
#
# The binding is what makes "just re-run the installer" safe: a repeat
# registration from the same fingerprint returns HTTP 200 with the SAME key_id,
# the same usage history and the same daily allowance, instead of minting a
# second key with a second allowance. (The key STRING is regenerated, because
# only a hash of the previous one was ever stored — the response says so.)
#
# NOTE: these limits are deliberately loose. People tether, travel and work from
# cafés; none of that should cost them their access. Exceeding either one is a
# self-clearing throttle with a clear message, NEVER a ban and never a
# suspension. Nothing here needs a human to un-stick it.

# Distinct IPs one key may be used from inside the window before it is slowed
# down. 0 disables. Keep this BELOW ABUSE_DISTINCT_IP_THRESHOLD so the soft
# throttle always fires before the hard resale check can suspend anybody.
MAX_IPS_PER_KEY=5
IP_BINDING_WINDOW_HOURS=24

# How long that throttle lasts, in seconds. It expires on its own.
BINDING_THROTTLE_SECONDS=60

# Keys actually ISSUED from one IP per UTC day. 0 disables. Different from
# REGISTER_MAX_PER_IP_PER_DAY above: that counts attempts (anti-probing), this
# counts successes (anti-farming). Re-registering a machine that already has a
# key does NOT count against it, so a re-install always works.
MAX_KEYS_PER_IP=3

# ── 4. Budgets ───────────────────────────────────────────────────────────────
# PER-KEY, per UTC day. 0 means unlimited for that dimension.
DAILY_TOKEN_BUDGET=2000000
DAILY_COST_USD_BUDGET=2.0

# THE OPERATOR'S BACKSTOP, per UTC month. This is what stops a viral post from
# becoming a surprise invoice. When it trips, the gateway degrades to read-only:
# /health, /usage and /v1/models keep answering, every request that would cost
# money returns 402, and NOTHING is forwarded upstream.
#
# 0 means unlimited. REGISTRATION_MODE=open with both caps at 0 is a startup
# error, not a warning.
GLOBAL_MONTHLY_USD_BUDGET=50.0

# A second ceiling, in tokens. Useful when you have not calibrated a price table
# and therefore cannot state a USD limit honestly. Either cap tripping is enough
# to switch the service read-only. 0 means unlimited.
GLOBAL_MONTHLY_TOKEN_BUDGET=0

# TODAY'S SLICE of the shared pool. Separate from the monthly cap because the
# two fail differently and users deserve to be told which one they hit: a daily
# cap means "come back after 00:00 UTC", a monthly cap means "come back on the
# 1st". Either one being set also satisfies the open-mode ceiling requirement.
# 0 means unlimited.
GLOBAL_DAILY_USD_BUDGET=0
GLOBAL_DAILY_TOKEN_BUDGET=0

# Fraction of the global cap at which to start warning in the logs.
GLOBAL_BUDGET_WARN_RATIO=0.9

# THE OPERATOR RESERVE. The bottom slice of the shared pool that only keys
# flagged `is_operator` may spend. Set with:
#     POST /admin/keys/<key_id>/operator  {"is_operator": true}
#
# Why this exists: the pool is funded out of the operator's own accounts, and
# the operator also has to get their own work done with it. Without a reserve,
# one busy afternoon of public traffic takes the operator's daily driver
# offline — and an operator whose own tools stop working turns the service off
# for everybody. Reserving a slice is what keeps the doors open at all.
#
# When remaining pool capacity drops to this fraction or below, non-operator
# keys get a friendly HTTP 429 (reason, reset_at, remaining_pct and BYOK
# instructions) instead of consuming it. Must be in [0, 1); 0 disables.
OPERATOR_RESERVE_FRACTION=0.25

# ── 5. Pricing ───────────────────────────────────────────────────────────────
# USD per 1,000,000 tokens. Set this or your cost budgets are guesses.
#
# `cached_input` MUST be priced separately from `input` — pricing a cached
# prompt token at the fresh rate would erase the entire point of this project.
# A 'default' entry is mandatory; without it an unpriced model would bill at
# zero and slip past every cost budget. Keys are matched exactly, then by
# longest prefix (so "yangble5" also prices "yangble5[1m]").
#
# The numbers below are PLACEHOLDERS, not a claim about any provider's rates.
# Look up what your upstream actually charges you and put that here.
PRICE_TABLE_JSON={"default":{"input":5.0,"cached_input":0.5,"output":15.0}}

# Or load the same JSON from a file instead (set one, not both).
PRICE_TABLE_FILE=

# ── 6. Rate limits and abuse ─────────────────────────────────────────────────
# NOTE: these limiters are in-process. Run ONE uvicorn worker, or divide these
# numbers by the worker count. The budgets in section 4 live in SQLite and are
# enforced correctly across workers regardless.
RATE_LIMIT_RPM=60

# Simultaneous in-flight requests per key. This is what bounds quota overshoot:
# a budget is checked before a request and charged after it, so N concurrent
# requests can each pass a check the others are about to invalidate.
RATE_LIMIT_CONCURRENCY=4

# Requests per minute per IP against /auth/register. 0 disables.
AUTH_RPM_PER_IP=10

# Failed auth attempts from one IP before lockout, and the base penalty. The
# penalty doubles for each further failure, capped at one hour so a shared NAT
# egress is never bricked permanently.
AUTH_FAIL_LOCKOUT_THRESHOLD=8
AUTH_FAIL_LOCKOUT_SECONDS=300

# Account-sharing / key-resale detection: distinct IPs seen for one key inside
# the window. IPs are stored only as salted hashes, never in the clear.
ABUSE_DISTINCT_IP_THRESHOLD=8
ABUSE_IP_WINDOW_HOURS=24

# false = log a warning and let it through (recommended at first, so you can see
# what normal looks like before you start suspending real users).
ABUSE_AUTO_SUSPEND=false

# How long a successful key verification is remembered, in seconds. This exists
# because scrypt costs tens of milliseconds by design and re-deriving it on
# every proxied request would make the gateway trivially CPU-DoS-able. Key
# STATUS is never cached, so a suspension still takes effect immediately.
AUTH_CACHE_TTL_SECONDS=300

# ── 6b. BYOK (bring your own key) ────────────────────────────────────────────
# Lets a registered user attach a credential for an upstream account THEY own
# (POST /byok). Their requests are then routed with it and stop drawing on the
# shared pool entirely: no daily allowance, no operator reserve. This is the
# pressure valve that lets a small pool say "here is how to keep going" instead
# of just "no".
BYOK_ENABLED=true

# HOW ATTACHED CREDENTIALS ARE STORED. There are exactly two modes and the
# gateway tells the user which one is in effect at the moment they attach, so
# nobody has to read this file to find out:
#
#   set    -> AES-256-GCM at rest under a key derived from this value. The
#             database alone is not enough to recover a credential. Requires the
#             optional `cryptography` package (pip install 'yangble5[byok]');
#             setting this without it is a STARTUP ERROR, not a silent
#             downgrade to plaintext.
#   unset  -> credentials are stored AS-IS in the SQLite file. Anyone who can
#             read that file or a backup of it can read them. That is the honest
#             default for an operator who has not configured a secret, and the
#             user is told so verbatim when they attach.
#
# Changing or clearing this later makes existing rows unreadable; those users
# fall back to the shared pool and can simply re-attach. It is not an outage.
BYOK_ENCRYPTION_KEY=

# Optional link included in the BYOK instructions the gateway hands out. The
# instructions are self-contained without it.
BYOK_DOCS_URL=

# ── 7. Transport ─────────────────────────────────────────────────────────────
# Largest request body accepted, in bytes. A 748K-token prompt is several MB.
MAX_REQUEST_BYTES=33554432

# Largest response body parsed for a usage block. Bigger responses are still
# forwarded untouched, just not billed by parsed usage.
MAX_USAGE_PARSE_BYTES=2097152

# Turn on ONLY when something you control (Caddy, nginx) sits in front and
# overwrites X-Forwarded-For. With this on and no such proxy, any client can
# forge its own IP and walk straight past every per-IP limit.
TRUST_PROXY_HEADERS=false

# Number of trusted proxies in front of the gateway. The client address is read
# this many entries from the END of X-Forwarded-For.
TRUSTED_PROXY_HOPS=1

# ── 8. Logging ───────────────────────────────────────────────────────────────
# One JSON object per line on stdout. The gateway logs metadata only — never a
# key, a prompt, a completion, or a raw IP address.
LOG_LEVEL=INFO
